<div class="chat-main">
  <div class="chat-header">
    <div class="chat-room-name">
      <%= @room.name %>
    </div>
    <div class="chat-room-exit">
      <%= link_to "チャットを終了する", room_path(@room), data: { turbo_method: :delete } %>
    </div>
  </div>
  <div class="chat-messages">
    <%= render partial: "message", collection: @messages %>
  </div>
  <div class="chat-input">
    <%= form_with model: [@room, @message], html: {class: "form"}, local: true do |f|%>
      <div class="form-input">
        <%= f.text_field :content, class: "send-content", placeholder: "type a message" %>
        <label class="image-btn">画像</label>
      </div>
      <%= f.submit "送信", class: "send-btn"%>
    <% end %>
  </div>
</div>